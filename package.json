{
  "name": "habitat",
  "version": "0.1.0",
  "description": "A tiny Bun and TypeScript prompt CLI.",
  "type": "module",
  "bin": {
    "habitat": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "web:dev": "vite web --host 127.0.0.1",
    "web:build": "vite build web --outDir ../dist/web --emptyOutDir"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "expr-eval": "^2.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "bun-types": "^1.3.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
